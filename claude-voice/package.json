  "description": "Voice-enabled wrapper for Claude Code CLI — adds alt+v push-to-talk via Whissle ASR",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "claude-voice": "./bin/claude-voice.mjs"
